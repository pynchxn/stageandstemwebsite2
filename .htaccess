ErrorDocument 404 /404.html

RewriteEngine On

# Canonical host: redirect www.stageandstem.com -> stageandstem.com
RewriteCond %{HTTP_HOST} ^www\.stageandstem\.com [NC]
RewriteRule ^(.*)$ https://stageandstem.com/$1 [R=301,L]

# Force HTTPS — uncomment the two lines below once SSL is provisioned on the domain.
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
